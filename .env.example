# Copy this file to .env for local development.
# Never commit real secrets in .env or .env.example.

# Public app URL used for production self-references and callbacks.
APP_URL=https://resto-flow-eta.vercel.app/

# MongoDB Atlas
# Replace <db_username> and <db_password> with your Atlas database user credentials.
# Keep /restoflow in the URI path so the app uses the intended database instead of MongoDB's default test database.
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@learningproject.3djrvwy.mongodb.net/restoflow?retryWrites=true&w=majority&appName=learningProject
MONGODB_DB=restoflow

# Optional Gemini key if AI features are enabled.
# GEMINI_API_KEY=your_gemini_api_key_here
